# submit.dag

JOB  A  me.submit
JOB  B  null.submit
JOB  C  inference.submit


VARS A file="simulation_data.hdf5"
VARS ALL_NODES clust_thresh="0.001"
VARS ALL_NODES iter="50"
VARS ALL_NODES num_studies="20"
VARS ALL_NODES num_true="5"
VARS ALL_NODES rep="2"
VARS ALL_NODES pt="False"

PARENT A CHILD B
PARENT B CHILD C